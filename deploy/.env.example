LOBBY_DOMAIN=chat.example.com
LIVEKIT_DOMAIN=livekit.example.com
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=please-change-to-32-plus-chars-random-string
# Cloudflare API token with Zone:DNS:Edit permission for the zone of your domain.
# Used by Caddy to solve ACME DNS-01 challenge (avoids HTTP-01/TLS-ALPN-01,
# which fail when the VPS is behind DPI/SNI filters or unreachable from
# Let's Encrypt's secondary validators). Create at:
#   https://dash.cloudflare.com/profile/api-tokens (template: Edit zone DNS)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
