node_modules/
dist/
.env
.env.local
.env.*
!.env.example
*.log
.DS_Store
release/
out/
.vite/
apps/server/uploads/

# Generated by apps/client/scripts/generate-icons.mjs (run automatically by build/package).
apps/client/build/icon.ico
apps/client/build/icon.png

# Tauri client
apps/client-tauri/dist/
apps/client-tauri/src-tauri/target/
apps/client-tauri/src-tauri/gen/
apps/client-tauri/src-tauri/icons/*.png
apps/client-tauri/src-tauri/icons/*.ico
apps/client-tauri/src-tauri/icons/*.icns

# Tauri updater signing keys — приватный ключ ни при каких условиях не должен попасть в репо.
# Папка `~/` появляется, если `tauri signer generate -w ~/.tauri/...` запустить под Windows
# (cmd/PowerShell не разворачивает `~`, и ключ ложится прямо внутрь проекта).
apps/client-tauri/~/
*.key
*.key.pub
