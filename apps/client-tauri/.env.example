# Скопируй этот файл в один из .env.<mode>:
#   .env.local-server   — для `npm run dev` / `npm run build`
#   .env.remote-server  — для `npm run dev:remote` / `npm run build:remote`
#
# Если файлов нет в apps/client-tauri/, Vite подхватит соседние из
# apps/client/.env.<mode> — оба клиента живут на одном lobby.

VITE_LOBBY_URL=https://app.voicechat-xyz.ru
