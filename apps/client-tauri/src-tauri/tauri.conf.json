{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceChat (Tauri)",
  "version": "0.1.2",
  "identifier": "com.voicechat.tauri",
  "build": {
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoiceChat",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#09090b",
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "VoiceChat (Tauri client)",
    "longDescription": "VoiceChat desktop client built with Tauri 2."
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ2MTg0QzNENkZBMDBFNTQKUldSVURxQnZQVXdZUmlyRkRwUkpTYW0xLzQxdWRJTG1nZjhYN2Q4dmJJV0RUbUNFZ3F6dlphMXkK",
      "endpoints": [
        "https://github.com/MiiZZo/voicechat-xyz/releases/latest/download/latest.json"
      ]
    }
  }
}
